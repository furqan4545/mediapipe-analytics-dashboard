# ── Supabase (same project as main mediapipe SaaS) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://gqodvpibtyqrrjixzlwx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Postgres (Supabase pooler, transaction mode) ───────────────────────
# Same DB the worker writes to. We only read analytics_* and linked_accounts.
DATABASE_URL=postgresql://postgres.gqodvpibtyqrrjixzlwx:MediaPipe2024@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── Worker (Hetzner sync-worker) ───────────────────────────────────────
# Public URL exposed via Caddy + Let's Encrypt.
NEXT_PUBLIC_WORKER_URL=https://analytics.kodeui.com

# ── Main SaaS (for redirects: missing-session / no-linked-accounts CTAs)
NEXT_PUBLIC_MAIN_SAAS_URL=https://hardlaunch.com

# ── Super admins (operator allowlist) ──────────────────────────────────
# Comma-separated emails that can access /admin and "view as" any customer.
# Falls back to the built-in operators if unset.
SUPER_ADMIN_EMAILS=faqi9500@gmail.com,furqan.adeveloper@gmail.com
